# Register a GitHub OAuth App at https://github.com/settings/applications/new
# - Application name: MindPalace
# - Homepage URL: https://github.com/your-username/mindpalace
# - Authorization callback URL: (leave blank — Device Flow does not require one)
# - Enable Device Flow: check the box
#
# Then paste your Client ID below. No client_secret is needed for Device Flow.
GITHUB_OAUTH_CLIENT_ID=placeholder
